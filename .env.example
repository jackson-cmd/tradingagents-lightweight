# Copy to .env and fill in only what you use. The tool runs with no keys at all
# (rule engine). Keys are only needed to turn the LLM decision layer on.

# Which model to use. Recommended for cost: gpt-4.1-mini (or gpt-4.1-nano).
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini

# API keys - set the one(s) for the provider you picked.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# News source: sec (free 8-K filings, default) | benzinga (paid, real-time) | rss (your own feed)
NEWS_SOURCE=sec
# rss source only - point at any market-news RSS feed:
# RSS_FEED_URL=

# Paid news feed for an earlier edge (optional).
BENZINGA_API_KEY=
# SEC EDGAR wants a descriptive User-Agent (your name/email).
SEC_USER_AGENT=tradingagents-lightweight you@example.com

# Trade construction.
RISK_REWARD=2.0
ATR_MULT=2.0
RISK_PER_TRADE=0.01
